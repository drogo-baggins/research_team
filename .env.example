# 検索モード: human | tavily | serper | brave
SEARCH_MODE=human

# 検索エンジンのベースURL（human モード用）
# テスト時はローカルサーバーに向けるため上書き可能
# デフォルト: https://www.google.com/search?q=
SEARCH_ENGINE_URL=https://www.google.com/search?q=

# API検索キー（SEARCH_MODE=human の場合は不要）
TAVILY_API_KEY=
SERPER_API_KEY=

# LLMプロバイダ（pi-agentが使用）
# GitHub Copilot を使う場合は API キー不要（下記「プロバイダ認証」参照）
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# pi-agent Node.js バイナリパス
PI_AGENT_BIN=pi

# pi-agent が使用する LLM モデル
# 形式: <provider>/<model-id>
# 例:
#   github-copilot/claude-sonnet-4.5   （デフォルト）
#   github-copilot/gpt-4o
#   openai/gpt-4o
#   anthropic/claude-opus-4-5
PI_MODEL=github-copilot/claude-sonnet-4.5

# 品質ループ設定
MAX_QUALITY_ITERATIONS=3
